# Port the API listens on
PORT=3000

# Allowed CORS origin for the React frontend (Vite default)
FRONTEND_ORIGIN=http://localhost:5173

# Postgres connection string (used in local dev and on Render)
# Local example: postgres://postgres:postgres@localhost:5432/firefly
# On Render: copy the Internal Database URL from the managed Postgres instance
DATABASE_URL=postgres://postgres:postgres@localhost:5432/firefly

# Base URL of the upstream PokeAPI proxied by the backend
POKEAPI_BASE_URL=https://pokeapi.co/api/v2
